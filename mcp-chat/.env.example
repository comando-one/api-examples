# Chave do Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-google-ai-studio-key
# Opcional — modelo (padrão: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Chave da API do Comando.One (Configurações → API Keys)
COMANDO_API_KEY=cmd_live_...
# Opcional — empresa específica (X-Company-Id)
COMANDO_COMPANY_ID=
